# コピーして .env として使用する: cp .env.example .env
# docker compose --env-file .env -f docker/docker-compose.yml up --build

POSTGRES_DB=novelshelf
POSTGRES_USER=novelshelf
POSTGRES_PASSWORD=novelshelf
POSTGRES_PORT=5433
# 5432はこのマシン上の他プロジェクト(jsa-db)が使用中のため既定値を5433にしている

BACKEND_PORT=8081
# 8080はこのマシン上の他プロジェクト(jsa-backend)が使用中のため既定値を8081にしている

FRONTEND_PORT=3002
# 3000/3001は他プロジェクトが使用中のため既定値を3002にしている
NEXT_PUBLIC_API_BASE_URL=http://localhost:8081/api/v1

# 本番では必ず32byte以上のランダムな値に変更すること（開発用の既定値のまま運用しない）
JWT_SECRET=dev-only-secret-key-change-me-please-32bytes-min
JWT_ACCESS_TTL_MINUTES=30
JWT_REFRESH_TTL_DAYS=30

# パスワードリセット機能のメール送信用。SMTPプロトコルであればプロバイダは問わない
# （Gmail SMTP / SendGrid・AWS SES等 / ConoHaメール等）。未設定のままでも起動はできるが、
# パスワードリセットメールは送信されない（失敗はログに記録されるのみ）。
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=no-reply@novelshelf.jp
PASSWORD_RESET_TTL_MINUTES=30

# Phase6でConoHa VPSへデプロイする際に有効化する（docs/DEPLOY.md参照）:
# DOMAIN=novelshelf.jp
# ACME_EMAIL=
# CORS_ALLOWED_ORIGINS=https://novelshelf.jp
# NEXT_PUBLIC_API_BASE_URL=https://novelshelf.jp/api/v1
